{
  "name": "peppol-validator",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prepare:runtime": "node scripts/prepare-static-runtime.mjs",
    "start": "npm run prepare:runtime && ng serve",
    "build": "npm run prepare:runtime && ng build",
    "build:ghpages": "npm run prepare:runtime && ng build --configuration production --base-href ./ --output-path docs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.5.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.6",
    "node-xsl-schematron": "^1.1.0",
    "rxjs": "~7.8.0",
    "saxon-js": "^2.7.0",
    "tslib": "^2.3.0",
    "xslt3": "^2.7.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
